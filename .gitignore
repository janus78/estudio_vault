# macOS / Windows
.DS_Store
Thumbs.db
Desktop.ini

# Linux / Unix metadata
._*
.directory

# Papelera y metadatos de sistemas operativos
.Trashes/
.Trash-*/
$RECYCLE.BIN/
System Volume Information/

# Archivos temporales y de edicion
*.tmp
*.temp
*.swp
*.swo
*~

# Temporales comunes de Microsoft Office
~$*

# Obsidian: estado local de la interfaz y cache
.obsidian/cache/
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/app.json
.obsidian/Cache/
.obsidian/backups/

# SEGURIDAD: Prevenir leaks de API Keys en plugins
.obsidian/plugins/**/data.json

# Conflictos de sincronización (Syncthing/Dropbox/iCloud/etc)
**/*.sync-conflict-*
**/*.icloud

# Papelera local del vault
.trash/
